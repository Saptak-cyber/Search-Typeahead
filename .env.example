# ---- PostgreSQL (primary store) ----
PG_URL=postgres://typeahead:typeahead@localhost:5432/typeahead

# ---- Redis cache nodes (comma-separated host:port list) ----
# Each entry is one logical/physical cache node placed on the consistent-hash ring.
REDIS_NODES=localhost:6379,localhost:6380,localhost:6381

# ---- Server ----
PORT=4000

# ---- Cache behavior ----
CACHE_TTL_SECONDS=60          # TTL for basic (count-sorted) suggestion entries
CACHE_TTL_RECENCY_SECONDS=10  # shorter TTL for recency-mode entries (rankings drift faster)
RING_REPLICAS=150             # virtual nodes per physical node on the hash ring

# ---- Batch writer ----
FLUSH_INTERVAL_MS=2000        # flush the search buffer at least this often
BATCH_SIZE=500                # ...or earlier once the buffer reaches this many items

# ---- Trending / recency ----
TREND_BOOST=1                 # score added per search to the trending ZSET
DECAY_FACTOR=0.95             # multiply all trending scores by this each decay tick
DECAY_INTERVAL_MS=10000       # how often the decay job runs
RECENCY_WEIGHT=0.5            # w2 in the blended score (w1 = 1 - RECENCY_WEIGHT)

# ---- Suggestions ----
SUGGEST_LIMIT=10
